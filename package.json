{
  "name": "liteduck",
  "private": true,
  "version": "2026.5.2",
  "type": "module",
  "description": "A lightweight code editor — file browser + editor, integrated terminal, and Git in a fast native desktop app. No AI, no clutter.",
  "license": "MIT",
  "homepage": "https://github.com/bemindlabs/liteduck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bemindlabs/liteduck.git"
  },
  "bugs": {
    "url": "https://github.com/bemindlabs/liteduck/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "npm run tauri dev",
    "build:prod": "npm run tauri build",
    "build:debug": "npm run tauri build -- --debug",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "quality-gate": "tsc --noEmit -p tsconfig.app.json && npm run format:check && npm run lint && vitest run --coverage && cd src-tauri && cargo check --all-targets && cargo fmt -- --check && cargo clippy -- -D warnings && cargo test"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^4.7.6",
    "react-router-dom": "^7.14.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.2"
  }
}
