# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
target/
src-tauri/target/
src-tauri/gen/
*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test / Coverage ───────────────────────────────────────────────────────────
coverage/

# Playwright (e2e)
playwright-report/
test-results/
blob-report/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/worktrees/

# ── App data (runtime) ────────────────────────────────────────────────────────
.agents/

# ── Signing / Distribution (local only) ──────────────────────────────────────
*.p12
*.cer
*.pem
*.provisionprofile
*.mobileprovision

# ── LiteDuck local data (ignore all local data, but keep the folder) ───────────────
# .LiteDuck
.LiteDuck
# Exception: src-tauri/.LiteDuck/ holds bundled resources (agent-card.json) that
# must ship with the app, not local user data.
!src-tauri/.LiteDuck
!src-tauri/.LiteDuck/**
